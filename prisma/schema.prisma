generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

enum AuctionStatus {
  UPCOMING
  ACTIVE
  ENDED
  SOLD
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  CANCELLED
}

enum NotificationType {
  OUTBID
  AUCTION_WON
  AUCTION_ENDING
  EMAIL_VERIFIED
  GENERIC
}

enum PasswordResetOtpChannel {
  EMAIL
  SMS
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phoneNumber   String    @unique
  passwordHash  String
  role          Role      @default(CUSTOMER)
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  bids          Bid[]
  properties    Property[] @relation("PropertyCreator")
  favorites     Favorite[]
  wonAuctions   Property[] @relation("AuctionWinner")
  refreshTokens            RefreshToken[]
  passwordResetTokens      PasswordResetToken[]
  passwordResetOtps        PasswordResetOtp[]
  emailVerificationTokens  EmailVerificationToken[]
  notifications            Notification[]
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetOtp {
  id          String                  @id @default(cuid())
  userId      String
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     PasswordResetOtpChannel
  codeHash    String
  expiresAt   DateTime
  attemptCount Int                    @default(0)
  maxAttempts Int                     @default(5)
  consumedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([userId, channel])
  @@index([expiresAt])
  @@unique([userId, channel])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  body       String
  readAt     DateTime?
  propertyId String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

model Property {
  id               String        @id @default(cuid())
  title            String
  description      String
  propertyType     String
  location         String
  city             String
  area             Float
  bedrooms         Int?
  bathrooms        Int?
  amenities        String[]
  images           String[]
  startingPrice    Float
  currentPrice     Float
  minimumIncrement Float         @default(5000)
  auctionStart     DateTime
  auctionEnd       DateTime
  status           AuctionStatus @default(UPCOMING)
  latitude         Float?
  longitude        Float?
  bidCount         Int           @default(0)
  winnerUserId     String?
  winner           User?         @relation("AuctionWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  createdById      String
  createdBy        User          @relation("PropertyCreator", fields: [createdById], references: [id])
  bids             Bid[]
  favorites        Favorite[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, propertyId])
  @@index([userId])
}

model Bid {
  id         String    @id @default(cuid())
  amount     Float
  status     BidStatus @default(ACTIVE)
  userId     String
  propertyId String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@index([propertyId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}
